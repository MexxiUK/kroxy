apiVersion: v1
kind: Secret
metadata:
  name: kroxy-secrets
  namespace: kroxy
  labels:
    app.kubernetes.io/name: kroxy
    app.kubernetes.io/component: secrets
type: Opaque
stringData:
  # IMPORTANT: Generate these values securely before deployment
  # Example: openssl rand -base64 32
  KROXY_JWT_SECRET: "CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32"
  KROXY_ENCRYPTION_KEY: "CHANGE_ME_32_BYTES_BASE64_ENCODED"
---
apiVersion: v1
kind: Secret
metadata:
  name: kroxy-admin-token
  namespace: kroxy
  labels:
    app.kubernetes.io/name: kroxy
    app.kubernetes.io/component: admin-token
type: Opaque
stringData:
  # Initial admin token - change this in production
  token: "CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32"