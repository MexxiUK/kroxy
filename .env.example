# Kroxy Environment Configuration
# Copy this file to .env and customize for your deployment.

# =============================================================================
# Core Server Settings
# =============================================================================

# HTTP listen address (public-facing proxy traffic)
# Default: :80
KROXY_PROXY=:80

# HTTPS listen address (when TLS is enabled)
# Default: :443
KROXY_HTTPS_ADDR=:443

# Admin API / dashboard listen address
# SECURITY NOTE: In production, keep this on localhost (127.0.0.1:8081) or enable TLS.
# Default: 127.0.0.1:8081
KROXY_ADMIN=127.0.0.1:8081

# SQLite database path
# In production mode, this must be an absolute path.
# Default: ./kroxy.db
KROXY_DB=/data/kroxy.db

# Production mode — enforces stricter security defaults
#   - Requires absolute KROXY_DB path
#   - Requires TLS or localhost for admin API
#   - Disallows KROXY_ALLOW_PRIVATE_BACKENDS
#   - Warns if audit signing key is not set
# Default: false
KROXY_PRODUCTION=false

# =============================================================================
# Request Handling
# =============================================================================

# Maximum request body size in bytes
# Default: 10485760 (10 MB)
KROXY_MAX_REQUEST_SIZE=10485760

# Allow backends on private IP ranges (e.g., 10.0.0.0/8, 192.168.0.0/16).
# Only enable in development. Blocked automatically in production mode.
# Default: false
KROXY_ALLOW_PRIVATE_BACKENDS=false

# =============================================================================
# TLS / HTTPS
# =============================================================================

# Enable TLS termination
# Default: false
KROXY_TLS_ENABLED=false

# Enable automatic HTTPS via ACME (Let's Encrypt)
# Requires KROXY_ACME_EMAIL when enabled.
# Default: false
KROXY_AUTO_HTTPS=false

# Email address for Let's Encrypt account and expiry notifications
# Required when KROXY_AUTO_HTTPS=true
KROXY_ACME_EMAIL=admin@example.com

# Path to manual TLS certificate PEM (when auto HTTPS is disabled)
# Must be an absolute path.
KROXY_TLS_CERT=/data/certs/cert.pem

# Path to manual TLS private key PEM (when auto HTTPS is disabled)
# Must be an absolute path.
KROXY_TLS_KEY=/data/certs/key.pem

# Minimum TLS version (1.2 or 1.3)
# Default: 1.2
KROXY_TLS_MIN_VERSION=1.2

# Redirect HTTP to HTTPS automatically
# Default: true
KROXY_REDIRECT_HTTP=true

# Enable HSTS (Strict-Transport-Security) header
# Only sent over HTTPS connections.
# Default: true
KROXY_HSTS_ENABLED=true

# =============================================================================
# Security & Sessions
# =============================================================================

# JWT secret for session signing and CSRF tokens
# GENERATE A STRONG RANDOM VALUE IN PRODUCTION.
# Default: auto-generated on first run (stored in database)
KROXY_JWT_SECRET=change-me-in-production-use-32-plus-chars

# Allow cookies without Secure flag (for local HTTP development only)
# Default: false
KROXY_INSECURE_COOKIES=false

# Strict session binding — bind sessions to IP + User-Agent
# Default: false (enabled automatically in production)
KROXY_STRICT_SESSION_BINDING=false

# Comma-separated list of trusted proxy IP addresses / CIDR ranges
# Used to correctly determine client IP behind a reverse proxy.
# Default: (empty — only direct connections trusted)
KROXY_TRUSTED_PROXIES=

# Comma-separated list of IP addresses allowed to access the admin API
# Overrides default localhost restriction. Use with caution.
# Default: (empty — localhost only)
KROXY_ADMIN_ALLOWED_IPS=

# =============================================================================
# Encryption & Signing
# =============================================================================

# AES-256-GCM encryption key for secrets at rest (TOTP seeds, OIDC client secrets)
# GENERATE A STRONG 32+ CHARACTER PASSPHRASE IN PRODUCTION.
# Default: derived from database path (not suitable for production)
KROXY_ENCRYPTION_KEY=change-me-in-production-use-32-plus-chars

# HMAC signing key for WAF verification headers and audit log integrity
# GENERATE A STRONG RANDOM VALUE IN PRODUCTION.
# Default: derived from database path (not suitable for production)
KROXY_WAF_SIGNING_KEY=change-me-in-production-use-32-plus-chars

# =============================================================================
# Audit & Logging
# =============================================================================

# Path to append-only audit log file
# If unset, audit events are logged to stderr only.
KROXY_AUDIT_LOG=/data/audit.log

# HMAC signing key for audit log integrity
# If unset, a key is derived from the database path.
# GENERATE A STRONG RANDOM VALUE IN PRODUCTION.
KROXY_AUDIT_SIGNING_KEY=change-me-in-production-use-32-plus-chars

# Webhook URL for audit event forwarding
# If set, audit events are POSTed to this URL with HMAC signatures.
KROXY_AUDIT_WEBHOOK_URL=

# Path to SQLite access log database
# If unset, access logs are kept in-memory (not persisted).
KROXY_ACCESS_LOG=/data/access.log

# =============================================================================
# Bot Protection (Optional)
# =============================================================================

# Secret key for bot protection challenges
# If unset, bot protection is disabled.
KROXY_BOT_SECRET=change-me-in-production-use-32-plus-chars

# =============================================================================
# Data Directory
# =============================================================================

# Base directory for data files (used by crypto layer as fallback)
KROXY_DATA_DIR=/data
